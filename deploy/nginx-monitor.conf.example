# 部署到出口机 192.168.10.51（或其它对外 nginx）
# 反代到 nobug 的 192.168.10.78:8787（uvicorn --host 0.0.0.0）
#
# 用法示例：
#   scp deploy/nginx-monitor.conf.example root@192.168.10.51:/etc/nginx/conf.d/raina-monitor.conf
#   按需改 server_name / 证书后：nginx -t && systemctl reload nginx

upstream raina_monitor {
    server 192.168.10.78:8787;
    keepalive 16;
}

server {
    listen 80;
    # 换成实际对外域名，例如 monitor.raina.tech
    server_name monitor.raina.tech;

    # 若走 HTTPS，取消注释并配置证书
    # listen 443 ssl http2;
    # ssl_certificate     /etc/nginx/certs/monitor.crt;
    # ssl_certificate_key /etc/nginx/certs/monitor.key;
    # if ($scheme = http) { return 301 https://$host$request_uri; }

    client_max_body_size 8m;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 采集刷新偶发稍慢，代理超时放宽
        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_pass http://raina_monitor;
    }
}
